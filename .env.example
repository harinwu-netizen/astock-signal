# A股信号灯 配置
# ========================

# ===== 股票池设置 =====
WATCHLIST_PATH=data/watchlist.json
POSITIONS_PATH=data/positions.json

# ===== 账户设置 =====
TOTAL_CAPITAL=100000
MAX_POSITIONS=3
SINGLE_TRADE_LIMIT=20000

# ===== 交易规则 =====
BUY_SIGNAL_THRESHOLD=5
SELL_SIGNAL_THRESHOLD=3
STOP_LOSS_PCT=10.0
TAKE_PROFIT_PCT=15.0
ATR_STOP_MULTIPLIER=2.0
OPEN_WINDOW_START=14:30
OPEN_WINDOW_END=15:00

# ===== 风控 =====
MARKET_CRASH_THRESHOLD=-2.0
MAX_SINGLE_POSITION_PCT=30.0
MAX_TOTAL_POSITION_PCT=80.0
MAX_TRADES_PER_DAY=1

# ===== 监控 =====
WATCH_INTERVAL=300
WATCH_ENABLED=true

# ===== 通知 ======
# 飞书 Webhook（从飞书群机器人设置中获取）
FEISHU_WEBHOOK_URL=

# 企业微信 Webhook
WECHAT_WEBHOOK_URL=

# 通知开关
NOTIFY_ENABLED=true
# 只推送不交易（推荐先开启，观察3天再关闭）
NOTIFY_ONLY=true
# 自动交易（默认关闭！）
AUTO_TRADE=false

# ===== 系统 =====
LOG_LEVEL=INFO
LOG_DIR=logs
DATABASE_PATH=data/trades.db

# ===== 大模型配置（AI增强报告）=====
# 是否启用AI增强（true/false）
LLM_ENABLED=false

# 模型提供商（deepseek/zhipu/doubao/qwen/minimax/openai）
LLM_PROVIDER=deepseek

# 具体模型名（各Provider默认值如下）
# deepseek: deepseek-chat
# zhipu: glm-4-flash
# doubao: doubao-pro
# qwen: qwen-plus
# minimax: MiniMax-Text-01
LLM_MODEL=deepseek-chat

# API Key（必填，从各平台获取）
LLM_API_KEY=

# API地址（使用默认值可不填）
# DeepSeek: https://api.deepseek.com/v1
# 智谱: https://open.bigmodel.cn/api/paas/v4
# 豆包: https://ark.cn-beijing.volces.com/api/v3
# 通义: https://dashscope.aliyuncs.com/compatible-mode/v1
# MiniMax: https://api.minimax.chat/v1
LLM_BASE_URL=

# API版本（仅部分平台需要）
LLM_API_VERSION=

# 超时秒数
LLM_TIMEOUT=30

# 最大输出token
LLM_MAX_TOKENS=1000

# 温度参数（低=稳定0.1-0.3，高=创意0.7-1.0）
LLM_TEMPERATURE=0.3
